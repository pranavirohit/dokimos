# Copy to .env and fill in. Never commit .env.

# Required: BIP-39 mnemonic used to derive the attestation signing key (keep secret).
MNEMONIC=

# Optional: HTTP port for the Fastify API (default 8080)
# PORT=8080

# Comma-separated browser origins allowed by CORS (defaults to localhost dev ports).
# CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Set to true only for debugging — logs OCR-derived content (PII). Never in production.
# DEBUG_OCR=false

# Include wallet address in GET /health (default: omit)
# EXPOSE_SIGNER_ADDRESS=false

# Expected Eigen app id for /api/verify-attestation (optional override)
# EIGEN_APP_ID=
