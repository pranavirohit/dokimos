/**
 * PayStand Checkout V5 Embedding Script
 * Provides simple script tag integration for V5 checkout
 * Generated at: 2026-04-06T00:39:03.752501Z
 */
(function() {
  'use strict';

  // PayStand Checkout V5 Embedding Object
  var PaystandCheckoutV5 = {

    /**
     * Create and embed checkout V5 iframe
     */
    create: function(config) {
      if (!config || !config.publishableKey) {
        console.error('PayStand Checkout V5: publishableKey is required');
        return;
      }

      // Default configuration
      var defaults = {
        containerId: 'paystand-checkout-container',
        mode: 'embed',
        environment: 'live',
        autoCloseDelay: 2000
      };

      // Merge config with defaults
      config = Object.assign({}, defaults, config);

      // Validate and sanitize callback functions
      var callbackKeys = ['onLoad', 'onClose', 'onPaymentComplete', 'onPaymentFailed',
                         'onTokenizationComplete', 'onTokenizationFailed', 'onCheckoutCancelled',
                         'onProcessingStarted', 'onError'];

      callbackKeys.forEach(function(key) {
        if (config[key] !== undefined && typeof config[key] !== 'function') {
          console.warn('PayStand Checkout V5: ' + key + ' is not a function, removing it. Type:', typeof config[key]);
          delete config[key];
        }
      });

      // Build checkout URL
      var baseUrl = this.getBaseUrl(config.environment);
      var params = new URLSearchParams({
        publishableKey: config.publishableKey
      });

      // Add parameters from config.params object
      if (config.params && typeof config.params === 'object') {
        for (var key in config.params) {
          if (config.params.hasOwnProperty(key) && config.params[key]) {
            params.append(key, config.params[key]);
          }
        }
      }

      // Automatically add embedded flag for iframe detection
      params.append('embedded', 'true');

      // Allow merchant to supply their own idempotency key so repeat payments
      // within the same page session don't collide.
      if (config.idempotencyKey) {
        params.append('idempotencyKey', config.idempotencyKey);
      }

      var checkoutUrl = baseUrl + '/?' + params.toString();

      console.log('PayStand Checkout V5: Loading URL:', checkoutUrl);

      // Set up PostMessage event listener
      this.setupMessageListener(config);

      if (config.mode === 'modal') {
        this.createModal(checkoutUrl, config);
      } else if (config.mode === 'popup') {
        this.createPopupButton(checkoutUrl, config);
      } else if (config.mode === 'redirect') {
        this.redirectToCheckout(checkoutUrl, config);
      } else {
        this.createEmbed(checkoutUrl, config);
      }
    },

    /**
     * Get base URL for environment
     */
    getBaseUrl: function(environment) {
      switch(environment) {
        case 'local':
        case 'localhost':
          return 'http://localhost:4000';
        case 'biz':
        case 'development':
          return 'https://checkout-v5.paystand.biz';
        case 'staging':
        case 'io':
          return 'https://checkout-v5.paystand.io';
        case 'sandbox':
        case 'co':
          return 'https://checkout-v5.paystand.co';
        case 'production':
        case 'live':
        default:
          return 'https://checkout-v5.paystand.com';
      }
    },

    /**
     * Create embedded iframe
     */
    createEmbed: function(url, config) {
      var container = document.getElementById(config.containerId);
      if (!container) {
        console.error('PayStand Checkout V5: Container element not found: ' + config.containerId);
        return;
      }

      // Clear existing content
      container.innerHTML = '';

      // Create loading spinner
      var lang = config.params && config.params.lang;
      var loadingDiv = this.createLoadingSpinner(lang);
      container.appendChild(loadingDiv);

      // Create iframe
      var iframe = document.createElement('iframe');
      iframe.src = url;
      iframe.width = '100%';
      iframe.height = '600px';
      iframe.frameBorder = '0';
      iframe.style.border = 'none';
      iframe.style.borderRadius = '8px';
      iframe.style.display = 'none';
      iframe.id = 'paystand-checkout-v5-iframe';

      // Handle iframe load
      iframe.onload = function() {
        loadingDiv.style.display = 'none';
        iframe.style.display = 'block';
        console.log('PayStand Checkout V5: Loaded successfully');
        if (config.onLoad) config.onLoad();
      };

      // Handle iframe error
      iframe.onerror = function() {
        loadingDiv.style.display = 'none';
        container.innerHTML = '<div style="text-align: center; padding: 50px; color: #666; font-family: Arial, sans-serif;">Failed to load checkout. Please try again.</div>';
        console.error('PayStand Checkout V5: Failed to load iframe');
        if (config.onError) config.onError('Failed to load iframe');
      };

      container.appendChild(iframe);
    },

    /**
     * Create a button that opens checkout in a popup window.
     * The popup runs as a first-party context so cookies are never blocked.
     * Completion events are sent back via postMessage from window.opener.
     */
    createPopupButton: function(url, config) {
      var container = document.getElementById(config.containerId);
      if (!container) {
        console.error('PayStand Checkout V5: Container element not found: ' + config.containerId);
        return;
      }

      container.innerHTML = '';

      var self = this;
      var buttonText = (config.popupButtonText) || 'Open Checkout';
      var btn = document.createElement('button');
      btn.id = 'paystand-checkout-v5-popup-btn';
      btn.textContent = buttonText;
      btn.style.cssText = [
        'display:inline-flex',
        'align-items:center',
        'justify-content:center',
        'padding:12px 28px',
        'background:#007cba',
        'color:#fff',
        'border:none',
        'border-radius:6px',
        'font-size:16px',
        'font-family:Arial,sans-serif',
        'cursor:pointer',
        'transition:background 0.2s'
      ].join(';');

      btn.onmouseover = function() { btn.style.background = '#005f8e'; };
      btn.onmouseout  = function() { btn.style.background = '#007cba'; };

      btn.onclick = function() {
        self.openPopup(url, config);
      };

      container.appendChild(btn);
      console.log('PayStand Checkout V5: Popup button created');
    },

    /**
     * Open a centered popup window for checkout.
     * Called directly from a click handler so it satisfies the user-gesture
     * requirement in Safari / mobile browsers.
     */
    openPopup: function(url, config) {
      var w = config.popupWidth  || 800;
      var h = config.popupHeight || 700;
      var left = Math.round((screen.width  / 2) - (w / 2));
      var top  = Math.round((screen.height / 2) - (h / 2));
      var features = [
        'width='  + w,
        'height=' + h,
        'left='   + left,
        'top='    + top,
        'scrollbars=yes',
        'resizable=yes',
        'toolbar=no',
        'menubar=no',
        'location=no'
      ].join(',');

      // Pass autoCloseDelay into the popup URL so the in-popup countdown can use it.
      var popupUrl = url;
      if (config.autoCloseDelay) {
        popupUrl = url + (url.indexOf('?') === -1 ? '?' : '&') + 'autoCloseDelay=' + encodeURIComponent(config.autoCloseDelay);
      }

      var popup = window.open(popupUrl, 'paystand_checkout_v5', features);

      if (!popup) {
        console.warn('PayStand Checkout V5: Popup was blocked — please allow popups for this site');
        if (config.onError) config.onError('Popup blocked');
        return;
      }

      this._activePopup = popup;
      console.log('PayStand Checkout V5: Popup opened');

      // Poll so we notice if the user closes the popup manually
      var self = this;
      var pollTimer = setInterval(function() {
        if (popup.closed) {
          clearInterval(pollTimer);
          self._activePopup = null;
          console.log('PayStand Checkout V5: Popup closed by user');
          if (config.onClose) config.onClose();
        }
      }, 500);

      if (config.onLoad) config.onLoad();
    },

    /**
     * Redirect the current tab to the checkout URL.
     * After payment, the server will redirect back to config.returnUrl.
     * No cookies / session issues because the user navigates directly.
     */
    redirectToCheckout: function(url, config) {
      if (!config.returnUrl) {
        console.error('PayStand Checkout V5: returnUrl is required for redirect mode');
        return;
      }

      var finalUrl = url + '&returnUrl=' + encodeURIComponent(config.returnUrl);
      console.log('PayStand Checkout V5: Redirecting to checkout:', finalUrl);
      window.location.href = finalUrl;
    },

    /**
     * Get modal dimensions based on viewCheckout parameter
     */
    getModalDimensions: function(viewCheckout) {
      // Default dimensions (matches V4 portal-medium)
      var dimensions = {
        width: '90%',
        maxWidth: '800px',
        height: '90%',
        maxHeight: '700px'
      };

      // Map viewCheckout values to dimensions (based on V4 behavior)
      switch(viewCheckout) {
        case 'portal-small':
          dimensions = {
            width: '80%',
            maxWidth: '500px',
            height: '80%',
            maxHeight: '600px'
          };
          break;
        case 'portal-medium':
        case 'portal':
          dimensions = {
            width: '90%',
            maxWidth: '800px',
            height: '90%',
            maxHeight: '700px'
          };
          break;
        case 'portal-large':
          dimensions = {
            width: '95%',
            maxWidth: '1000px',
            height: '90%',
            maxHeight: '800px'
          };
          break;
        case 'portal-xlarge':
          dimensions = {
            width: '95%',
            maxWidth: '1200px',
            height: '95%',
            maxHeight: '900px'
          };
          break;
        case 'mobile':
          dimensions = {
            width: '100%',
            maxWidth: '400px',
            height: '100%',
            maxHeight: '600px'
          };
          break;
        default:
          // Keep default dimensions for unknown values
          break;
      }

      return dimensions;
    },

    /**
     * Create modal overlay with iframe
     */
    createModal: function(url, config) {
      // Create modal overlay
      var overlay = document.createElement('div');
      overlay.id = 'paystand-checkout-v5-modal';
      overlay.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
      `;

      // Get modal dimensions based on viewCheckout parameter
      var dimensions = this.getModalDimensions(config.params && config.params.viewCheckout);

      // Create modal content
      var modal = document.createElement('div');
      modal.style.cssText = `
        background: white;
        border-radius: 8px;
        width: ` + dimensions.width + `;
        max-width: ` + dimensions.maxWidth + `;
        height: ` + dimensions.height + `;
        max-height: ` + dimensions.maxHeight + `;
        position: relative;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
      `;

      // Create close button
      var closeBtn = document.createElement('button');
      closeBtn.innerHTML = '×';
      closeBtn.style.cssText = `
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        z-index: 10000;
        color: #666;
      `;

      // Create loading spinner for modal
      var lang = config.params && config.params.lang;
      var loadingDiv = this.createLoadingSpinner(lang);
      loadingDiv.style.cssText = `
        display: flex;
        justify-content: center;
        align-items: center;
        flex: 1;
        background: #f8f9fa;
        border-radius: 8px;
        margin: 0;
      `;

      // Create iframe container
      var iframeContainer = document.createElement('div');
      iframeContainer.style.cssText = `
        flex: 1;
        display: none;
        border-radius: 8px;
        overflow: hidden;
      `;

      // Create iframe
      var iframe = document.createElement('iframe');
      iframe.src = url;
      iframe.width = '100%';
      iframe.height = '100%';
      iframe.frameBorder = '0';
      iframe.style.border = 'none';
      iframe.style.borderRadius = '8px';
      iframe.id = 'paystand-checkout-v5-iframe';

      // Add event listeners
      var self = this;
      closeBtn.onclick = function() {
        self.closeModal();
        if (config.onClose) config.onClose();
      };

      overlay.onclick = function(e) {
        if (e.target === overlay) {
          self.closeModal();
          if (config.onClose) config.onClose();
        }
      };

      // Handle iframe loading
      iframe.onload = function() {
        loadingDiv.style.display = 'none';
        iframeContainer.style.display = 'flex';
        console.log('PayStand Checkout V5: Modal loaded successfully');
        if (config.onLoad) config.onLoad();
      };

      // Handle iframe error
      iframe.onerror = function() {
        loadingDiv.style.display = 'none';
        iframeContainer.innerHTML = '<div style="display: flex; align-items: center; justify-content: center; height: 100%; text-align: center; padding: 50px; color: #666; font-family: Arial, sans-serif;">Failed to load checkout. Please try again.</div>';
        iframeContainer.style.display = 'flex';
        console.error('PayStand Checkout V5: Failed to load modal iframe');
        if (config.onError) config.onError('Failed to load iframe');
      };

      // Assemble modal
      iframeContainer.appendChild(iframe);
      modal.appendChild(closeBtn);
      modal.appendChild(loadingDiv);
      modal.appendChild(iframeContainer);
      overlay.appendChild(modal);
      document.body.appendChild(overlay);

      console.log('PayStand Checkout V5: Modal opened successfully');
    },

    /**
     * Close modal
     */
    closeModal: function() {
      var modal = document.getElementById('paystand-checkout-v5-modal');
      if (modal) {
        document.body.removeChild(modal);
        console.log('PayStand Checkout V5: Modal closed');
      }
    },

    /**
     * Create loading spinner
     * @param {string} lang - Language code for translation (en, es, fr)
     */
    createLoadingSpinner: function(lang) {
      // Translation map for loading text
      var translations = {
        'en': 'Loading checkout...',
        'es': 'Cargando checkout...',
        'fr': 'Chargement du paiement...'
      };

      // Safely get the language, defaulting to 'en' if missing, invalid, or not supported
      var safeLang = (typeof lang === 'string' && lang.trim() !== '') ? lang.trim().toLowerCase() : 'en';
      var loadingMessage = translations[safeLang] || translations['en'];

      var loadingDiv = document.createElement('div');
      loadingDiv.style.cssText = `
        display: flex;
        justify-content: center;
        align-items: center;
        height: 600px;
        background: #f8f9fa;
        border-radius: 8px;
      `;

      var spinner = document.createElement('div');
      spinner.style.cssText = `
        width: 40px;
        height: 40px;
        border: 4px solid #e3e3e3;
        border-top: 4px solid #007cba;
        border-radius: 50%;
        animation: paystand-spin 1s linear infinite;
      `;

      var loadingText = document.createElement('div');
      loadingText.innerHTML = loadingMessage;
      loadingText.style.cssText = `
        margin-left: 15px;
        color: #666;
        font-family: Arial, sans-serif;
        font-size: 14px;
      `;

      // Add CSS animation for spinner
      if (!document.getElementById('paystand-spinner-style')) {
        var style = document.createElement('style');
        style.id = 'paystand-spinner-style';
        style.innerHTML = `
          @keyframes paystand-spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
          }
        `;
        document.head.appendChild(style);
      }

      var spinnerContainer = document.createElement('div');
      spinnerContainer.style.display = 'flex';
      spinnerContainer.style.alignItems = 'center';
      spinnerContainer.appendChild(spinner);
      spinnerContainer.appendChild(loadingText);

      loadingDiv.appendChild(spinnerContainer);
      return loadingDiv;
    },

    /**
     * Set up PostMessage listener with deduplication
     */
    setupMessageListener: function(config) {
      var self = this;

      // Clean up any existing listener first
      if (this._currentMessageListener) {
        window.removeEventListener('message', this._currentMessageListener);
      }

      var messageListener = function(event) {
        // Validate origin for security (allow PayStand domains)
        var allowedOrigins = [
          'https://checkout-v5.paystand.com',
          'https://checkout-v5.paystand.io',
          'https://checkout-v5.paystand.co',
          'https://checkout-v5.paystand.biz'
        ];

        if (!allowedOrigins.some(function(origin) { return event.origin.includes('paystand'); })) {
          return;
        }

        if (!event.data || !event.data.type) {
          return;
        }

        // Handle both PayStand prefixed and non-prefixed events
        var eventType = event.data.type;
        if (!eventType.startsWith('paystand_')) {
          switch(eventType) {
            case 'payment_completed':
              eventType = 'paystand_payment_completed';
              break;
            case 'payment_failed':
              eventType = 'paystand_payment_failed';
              break;
            case 'tokenization_completed':
              eventType = 'paystand_tokenization_completed';
              break;
            case 'tokenization_failed':
              eventType = 'paystand_tokenization_failed';
              break;
            case 'checkout_error':
              eventType = 'paystand_error';
              break;
            default:
              return;
          }
        }

        // Simple deduplication using timestamp + event type
        var timestamp = event.data.data?.timestamp;
        var eventKey = timestamp + '_' + eventType.replace('paystand_', '');

        window._paystandProcessedEvents = window._paystandProcessedEvents || new Set();

        if (window._paystandProcessedEvents.has(eventKey)) {
          console.log('PayStand Checkout V5: Duplicate event detected - skipping:', eventKey);
          return;
        }

        window._paystandProcessedEvents.add(eventKey);
        console.log('PayStand Checkout V5: Processing event:', eventType, event.data.data);

        // Handle events
        switch(eventType) {
          case 'paystand_payment_completed':
            self.handleCompletion(config, event.data, 'payment');
            if (typeof config.onPaymentComplete === 'function') {
              config.onPaymentComplete(event.data.data);
            }
            break;

          case 'paystand_tokenization_completed':
            self.handleCompletion(config, event.data, 'tokenization');
            if (typeof config.onTokenizationComplete === 'function') {
              config.onTokenizationComplete(event.data.data);
            }
            break;

          case 'paystand_payment_failed':
            if (typeof config.onPaymentFailed === 'function') {
              config.onPaymentFailed(event.data.data);
            }
            break;

          case 'paystand_tokenization_failed':
            if (typeof config.onTokenizationFailed === 'function') {
              config.onTokenizationFailed(event.data.data);
            }
            break;

          case 'paystand_error':
            if (typeof config.onError === 'function') {
              config.onError(event.data.data);
            }
            break;

        }
      };

      // Add event listener
      window.addEventListener('message', messageListener);
      this._currentMessageListener = messageListener;
    },

    /**
     * Handle completion events (payment, tokenization)
     */
    handleCompletion: function(config, eventData, type) {
      if (config.mode === 'modal') {
        var delay = (type === 'cancelled') ? 0 : (config.autoCloseDelay || 2000);
        setTimeout(function() {
          PaystandCheckoutV5.closeModal();
          if (config.onClose) config.onClose();
        }, delay);
      } else if (config.mode === 'popup') {
        var delay = (type === 'cancelled') ? 0 : (config.autoCloseDelay || 2000);
        setTimeout(function() {
          if (PaystandCheckoutV5._activePopup && !PaystandCheckoutV5._activePopup.closed) {
            PaystandCheckoutV5._activePopup.close();
            PaystandCheckoutV5._activePopup = null;
          }
          if (config.onClose) config.onClose();
        }, delay);
      }
    },

    /**
     * Destroy checkout and clean up resources
     */
    destroy: function(containerId) {
      containerId = containerId || 'paystand-checkout-container';

      // Clear embedded checkout / popup button
      var container = document.getElementById(containerId);
      if (container) {
        container.innerHTML = '';
        console.log('PayStand Checkout V5: Destroyed embedded checkout');
      }

      // Close any open popup
      if (this._activePopup && !this._activePopup.closed) {
        this._activePopup.close();
        this._activePopup = null;
      }

      // Close any open modals
      this.closeModal();

      // Clean up event listeners
      if (this._currentMessageListener) {
        window.removeEventListener('message', this._currentMessageListener);
        this._currentMessageListener = null;
        console.log('PayStand Checkout V5: Cleaned up message listener');
      }

      // Clear processed events cache
      if (window._paystandProcessedEvents) {
        window._paystandProcessedEvents.clear();
        console.log('PayStand Checkout V5: Cleared processed events cache');
      }

      console.log('PayStand Checkout V5: Destroyed successfully');
    }
  };

  // Auto-initialization from script tag
  function initFromScriptTag() {
    var script = document.getElementById('paystand_checkout_v5');
    if (!script) return;

    // Extract attributes from script tag
    var config = {
      publishableKey: script.getAttribute('ps-publishable-key'),
      environment: script.getAttribute('ps-env') || 'live',
      mode: script.getAttribute('ps-mode') || 'embed',
      containerId: script.getAttribute('ps-container-id') || 'paystand-checkout-container',
      returnUrl: script.getAttribute('ps-return-url') || null,
      idempotencyKey: script.getAttribute('ps-idempotency-key') || null,
      params: {}
    };

    // Extract ALL supported parameters
    var moduleParams = [
      // Core module parameters
      'ps-module',
      'ps-ext-invoice-id',
      'ps-ext-customer-id',
      'ps-ext-sales-order-id',
      'ps-ext-sales-invoice-id',
      'ps-receivable-group-id',
      'ps-sales-order-group-id',
      'ps-mandate-request-id',

      // Payment configuration
      'ps-payment-amount',
      'ps-payment-currency',
      'ps-fixed-amount',

      // UI & Display
      'ps-view-checkout',
      'ps-external-css',
      'ps-lang',

      // Customer information
      'ps-email',

      // Advanced configuration
      'ps-custom-preset',
      'ps-auto-pay-eligible',
      'ps-araproject-id',

      // Multi-currency & Multi-sub
      'ps-is-multi-sub',
      'ps-subsidiary-id',

      // ERP Integration
      'ps-is-quote',
      'ps-is-customer-deposit',
      'ps-account-key',
      'ps-erp-payment-type',
      'ps-erp-invoice-id',
      'ps-ns-params',
      'ps-preserve-ns-payer',

      // Advanced features
      'ps-description',

      // SPEI parameters
      'ps-spei-account-number',
      'ps-spei-account-holder-name',
      'ps-spei-reference-number',
      'ps-spei-bank-name'
    ];

    moduleParams.forEach(function(param) {
      var value = script.getAttribute(param);
      if (value) {
        // Convert ps-ext-invoice-id to extInvoiceId format
        var key = param.replace('ps-', '').replace(/-([a-z])/g, function(match, letter) {
          return letter.toUpperCase();
        });
        config.params[key] = value;
      }
    });

    // Set up default callbacks with console logging only
    config.onPaymentComplete = function(data) {
      console.log('PayStand Checkout V5: Payment completed successfully', data);
    };

    config.onPaymentFailed = function(data) {
      console.log('PayStand Checkout V5: Payment failed', data);
    };

    config.onTokenizationComplete = function(data) {
      console.log('PayStand Checkout V5: Payment method added successfully', data);
    };

    config.onTokenizationFailed = function(data) {
      console.log('PayStand Checkout V5: Failed to add payment method', data);
    };


    config.onLoad = function() {
      console.log('PayStand Checkout V5: Checkout loaded successfully');
    };

    config.onClose = function() {
      console.log('PayStand Checkout V5: Checkout closed');
    };

    config.onError = function(error) {
      console.error('PayStand Checkout V5: Checkout error', error);
    };

    // Auto-create if ps-show="true"
    if (script.getAttribute('ps-show') === 'true') {
      // Create container if it doesn't exist
      if (!document.getElementById(config.containerId)) {
        var container = document.createElement('div');
        container.id = config.containerId;
        container.style.cssText = 'width: 100%; height: 600px; border: 1px solid #ccc; margin: 20px 0;';
        script.parentNode.insertBefore(container, script.nextSibling);
      }

      PaystandCheckoutV5.create(config);
    }

    // Set up button handlers
    setupButtonHandlers(config);
  }

  // Button handler setup
  function setupButtonHandlers(baseConfig) {
    var buttons = document.querySelectorAll('.paystand-button-v5');
    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        var buttonConfig = Object.assign({}, baseConfig);
        buttonConfig.mode = button.getAttribute('ps-mode') || buttonConfig.mode;

        // Override with button-specific attributes (use same list as script tag)
        var buttonParams = [
          // Core module parameters
          'ps-module',
          'ps-ext-invoice-id',
          'ps-ext-customer-id',
          'ps-ext-sales-order-id',
          'ps-receivable-group-id',

          // Payment configuration
          'ps-payment-amount',
          'ps-payment-currency',
          'ps-fixed-amount',

          // UI & Display
          'ps-view-checkout',
          'ps-external-css',
          'ps-lang',

          // Customer information
          'ps-email',

          // Advanced configuration
          'ps-custom-preset',
          'ps-auto-pay-eligible',
          'ps-araproject-id',

          // Multi-currency & Multi-sub
          'ps-is-multi-sub',
          'ps-subsidiary-id',

          // ERP Integration
          'ps-is-quote',
          'ps-is-customer-deposit',
          'ps-account-key',
          'ps-erp-payment-type',
          'ps-erp-invoice-id',
          'ps-ns-params',
          'ps-preserve-ns-payer',

          // Advanced features
          'ps-description',

          // SPEI parameters
          'ps-spei-account-number',
          'ps-spei-account-holder-name',
          'ps-spei-reference-number',
          'ps-spei-bank-name'
        ];

        buttonParams.forEach(function(param) {
          var value = button.getAttribute(param);
          if (value) {
            var key = param.replace('ps-', '').replace(/-([a-z])/g, function(match, letter) {
              return letter.toUpperCase();
            });
            buttonConfig.params[key] = value;
          }
        });

        PaystandCheckoutV5.create(buttonConfig);
      });
    });
  }

  // Make available globally
  window.PaystandCheckoutV5 = PaystandCheckoutV5;

  // Auto-initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFromScriptTag);
  } else {
    initFromScriptTag();
  }

})();
